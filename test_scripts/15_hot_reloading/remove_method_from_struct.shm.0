// Snapshot 0: create a Greeter and set its name to a non-default value.
struct Greeter {
    name = "?",

    fn hello(self) {
        print("hello \(self.name)")
    }

    fn bye(self) {
        print("bye \(self.name)")
    }
}

let g = Greeter()
g.name = "world"

fn loop() {
    g.hello()
    g.bye()
}
