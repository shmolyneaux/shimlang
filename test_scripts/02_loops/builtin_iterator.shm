// The builtin `Iterator(func)` returns an iterable backed by a function,
// letting users implement iterators without defining a bespoke struct.
// Calling next on the iterator defers to the provided function; returning
// StopIteration ends iteration.

// Count from 1 up to 5 using a closure over `n`.
let n = 0
let counter = Iterator(fn() {
    n = n + 1
    if n > 5 {
        return StopIteration
    }
    return n
})

let collected = []
for x in counter {
    collected.append(x)
}
assert(collected.len() == 5)
assert(collected[0] == 1)
assert(collected[4] == 5)

// It composes with other iterable consumers like `map`.
let m = 0
let squares = Iterator(fn() {
    m = m + 1
    if m > 3 {
        return StopIteration
    }
    return m * m
})
let mapped = map(squares, fn(x) { x + 1 })
assert(mapped[0] == 2)
assert(mapped[1] == 5)
assert(mapped[2] == 10)

// An iterator that immediately stops yields nothing.
let empty = Iterator(fn() { StopIteration })
let count = 0
for _ in empty {
    count = count + 1
}
assert(count == 0)

// `Iterator(...)` can be returned directly from a struct's `iter` method,
// since the object it returns is both an iterable and an iterator.
struct CountDown {
    fn iter(self) {
        let num = 5
        Iterator(fn () {
            let ret = if num < 0 {
                StopIteration
            } else {
                num
            }
            num -= 1
            ret
        })
    }
}

let out = []
for x in CountDown() {
    out.append(x)
}
assert(out == [5, 4, 3, 2, 1, 0])

print("Builtin Iterator passed")
