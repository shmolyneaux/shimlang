let a = 4.0;
let b = 9;
let c = 3.7;
let d = 3.2;
let e = -3.7;
let f = 2.0;
let g = 2;
let h = 1.0;
let zero = 0.0;
let izero = 0;
let neg = -2.5;
let four = 4.0;
let oneeighty = 180.0;
let one_rad = 1.0;
let eight_f = 8.0;
let hundred_f = 100.0;
let three_f = 3.0;

print(a.sqrt());
print(b.sqrt());
print(f.pow(exp=c));
print(g.pow(exp=3));
print(g.pow(exp=-1));
print(f.pow(exp=-1));
print(c.round());
print(d.round());
print(e.round());
print(c.ceil());
print(d.ceil());
print(e.ceil());
print(c.floor());
print(d.floor());
print(e.floor());
print(b.round());
print(b.ceil());
print(b.floor());
print((-3).signum());
print(izero.signum());
let five = 5;
print(five.signum());
print(neg.signum());
print(four.recip());
print(g.recip());
print(c.frac());
print(e.frac());
print(three_f.frac());
print(b.frac());
print(c.trunc());
print(e.trunc());
print(b.trunc());
print(zero.sin());
print(zero.cos());
print(zero.tan());
print(zero.asin());
print(h.acos());
print(h.atan());
print(h.atan2(other=h));
print(zero.sinh());
print(zero.cosh());
print(zero.tanh());
print(zero.asinh());
print(h.acosh());
print(zero.atanh());
print(h.ln());
print(eight_f.log2());
print(b.log2());
print(hundred_f.log10());
let hundred_i = 100;
print(hundred_i.log10());
print(eight_f.log(base=f));
print(one_rad.to_degrees());
print(oneeighty.to_radians());
print(izero.to_degrees());
print(izero.to_radians());
